# Zoom RTMS OAuth / event settings
ZM_RTMS_CLIENT=your_zoom_rtms_client_id
ZM_RTMS_SECRET=your_zoom_rtms_client_secret
ZOOM_WEBHOOK_SECRET_TOKEN=your_zoom_event_secret_token

# Use websocket for firewall-friendly outbound event delivery, or webhook for inbound POST /webhook.
ZOOM_EVENT_SUBSCRIPTION_MODE=websocket
ZOOM_EVENT_WS_ENDPOINT=wss://ws.zoom.us/ws?subscriptionId=your_subscription_id
ZOOM_EVENT_WS_HEARTBEAT_MS=30000
ZOOM_EVENT_WS_RECONNECT_MIN_MS=2000
ZOOM_EVENT_WS_RECONNECT_MAX_MS=60000

PORT=8080
WEBHOOK_PATH=/webhook

# Windmill target
WINDMILL_BASE_URL=https://windmill.app.thatworkshop.dev
WINDMILL_WORKSPACE=that-workshop
WINDMILL_TOKEN=your_windmill_api_token
WINDMILL_SCRIPT_PATH=f/workshop_signal_compiler/zoom_rtms_transcript_chunk_to_signal

# Optional behavior
DRY_RUN=false
LOG_LEVEL=info
