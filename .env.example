# Zoom RTMS OAuth / webhook settings
ZM_RTMS_CLIENT=your_zoom_rtms_client_id
ZM_RTMS_SECRET=your_zoom_rtms_client_secret
ZOOM_WEBHOOK_SECRET_TOKEN=your_zoom_webhook_secret_token
PORT=8080
WEBHOOK_PATH=/webhook

# Windmill target
WINDMILL_BASE_URL=https://windmill.app.thatworkshop.dev
WINDMILL_WORKSPACE=that-workshop
WINDMILL_TOKEN=your_windmill_api_token
WINDMILL_SCRIPT_PATH=f/workshop_signal_compiler/zoom_rtms_transcript_chunk_to_signal

# Optional behavior
DRY_RUN=false
LOG_LEVEL=info
